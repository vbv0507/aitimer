<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
        <div class="glass p-6" data-aos="fade-up">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-2xl font-semibold text-slate-800 dark:text-white">Today's Schedule</h2>
                <div class="text-slate-500 font-medium">
                    <%= new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' }) %>
                </div>
            </div>

            <% if (!schedule || schedule.timeline.length === 0) { %>
                <div class="text-center py-12 bg-slate-50 dark:bg-slate-800/50 rounded-xl border border-slate-100 dark:border-slate-700">
                    <div class="w-16 h-16 bg-slate-200 dark:bg-slate-700 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fa-solid fa-mug-hot text-2xl text-slate-400"></i>
                    </div>
                    <p class="text-slate-500 dark:text-slate-400 font-medium">Your day is completely open.</p>
                    <a href="/planner" class="mt-4 inline-flex items-center bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-lg transition-colors font-medium shadow-sm">
                        <i class="fa-solid fa-plus mr-2"></i> Add Tasks
                    </a>
                </div>
            <% } else { %>
                <div class="relative border-l-2 border-slate-200 dark:border-slate-700 ml-4 space-y-8 pb-4">
                    <% schedule.timeline.forEach((item, index) => { %>
                        <div class="relative pl-8">
                            <% if (item.type === 'Lunch') { %>
                                <div class="absolute -left-3.5 top-1 w-7 h-7 bg-yellow-500 rounded-full border-4 border-white dark:border-slate-900 flex items-center justify-center shadow-sm">
                                    <i class="fa-solid fa-utensils text-[10px] text-white"></i>
                                </div>
                            <% } else { %>
                                <div class="absolute -left-3 top-1.5 w-6 h-6 bg-indigo-500 rounded-full border-4 border-white dark:border-slate-900 shadow-sm"></div>
                            <% } %>
                            
                            <div class="glass p-5 <%= item.type === 'Lunch' ? 'border-l-4 border-l-yellow-500' : 'border-l-4 border-l-indigo-500' %> transition-transform hover:-translate-y-1 shadow-sm">
                                <div class="flex justify-between items-start">
                                    <div>
                                        <h3 class="font-bold text-lg <%= item.type === 'Lunch' ? 'text-yellow-600 dark:text-yellow-400' : 'text-slate-800 dark:text-white' %> mb-1"><%= item.title %></h3>
                                        <div class="text-sm font-medium text-slate-500 dark:text-slate-400 flex items-center">
                                            <i class="fa-regular fa-clock mr-1.5 text-slate-400"></i>
                                            <%= new Date(item.startTime).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %> - 
                                            <%= new Date(item.endTime).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                                        </div>
                                    </div>
                                    <% if (item.type === 'Task' && item.taskId) { %>
                                        <div class="flex space-x-2">
                                            <% if (item.taskId.status !== 'Completed') { %>
                                                <button onclick="updateTaskStatus('<%= item.taskId._id %>', 'Completed')" class="text-slate-300 hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors" title="Complete">
                                                    <i class="fa-solid fa-circle-check text-2xl"></i>
                                                </button>
                                            <% } %>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>
    </div>

    <div class="space-y-6">
        <!-- AI Insights Card -->
        <div class="glass p-6 border-t-4 border-t-cyan-500" data-aos="fade-up" data-aos-delay="100">
            <h2 class="text-xl font-semibold mb-4 flex items-center text-cyan-600 dark:text-cyan-400">
                <i class="fa-solid fa-sparkles mr-2"></i> AI Assistant
            </h2>
            <div class="bg-cyan-50/50 dark:bg-cyan-900/10 p-5 rounded-xl border border-cyan-100 dark:border-cyan-800/30 text-slate-700 dark:text-slate-200 shadow-inner">
                <p class="text-sm leading-relaxed font-medium"><%= typeof aiInsight !== 'undefined' ? aiInsight : 'Loading AI Insights...' %></p>
            </div>
        </div>

        <!-- Quick Summary Card -->
        <div class="glass p-6" data-aos="fade-up" data-aos-delay="150">
            <h2 class="text-lg font-semibold mb-4 text-slate-800 dark:text-white">Today's Progress</h2>
            
            <% 
                const pendingCount = tasks.length;
                const completedCount = schedule ? schedule.timeline.filter(t => t.type === 'Task' && t.taskId && t.taskId.status === 'Completed').length : 0;
                const totalMins = tasks.reduce((sum, t) => sum + t.estimatedDuration, 0);
            %>
            
            <div class="grid grid-cols-2 gap-4">
                <div class="bg-slate-50 dark:bg-slate-700 p-4 rounded-xl text-center">
                    <div class="text-3xl font-bold text-indigo-600 dark:text-indigo-400 mb-1"><%= pendingCount %></div>
                    <div class="text-xs font-medium text-slate-500 uppercase tracking-wider">Pending Tasks</div>
                </div>
                <div class="bg-slate-50 dark:bg-slate-700 p-4 rounded-xl text-center">
                    <div class="text-3xl font-bold text-amber-500 mb-1"><%= totalMins %></div>
                    <div class="text-xs font-medium text-slate-500 uppercase tracking-wider">Est. Minutes</div>
                </div>
            </div>
            
            <a href="/planner" class="mt-6 w-full inline-flex justify-center items-center bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-600 hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 px-4 py-2 rounded-lg transition-colors text-sm font-medium shadow-sm">
                View Backlog <i class="fa-solid fa-arrow-right ml-2"></i>
            </a>
        </div>
    </div>
</div>

<script>
async function updateTaskStatus(taskId, status) {
    try {
        const res = await fetch(`/api/tasks/${taskId}/status`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ status })
        });
        if (res.ok) {
            window.location.reload();
        }
    } catch (err) {
        console.error(err);
    }
}
</script>

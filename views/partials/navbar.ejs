<% if (typeof user != 'undefined') { %>
<nav class="glass mx-4 mt-4 px-6 py-4 flex justify-between items-center z-50 sticky top-4">
    <div class="flex items-center space-x-2">
        <div class="w-8 h-8 rounded-lg bg-slate-900 dark:bg-white flex items-center justify-center shadow-sm">
            <i class="fa-solid fa-clock text-white dark:text-slate-900"></i>
        </div>
        <span class="text-xl font-bold text-slate-900 dark:text-white tracking-tight">TimeManager</span>
    </div>
    
    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center space-x-6">
        <div class="relative group flex items-center h-full py-2">
            <button class="text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-white flex items-center transition-colors">
                <i class="fa-solid fa-palette mr-2"></i> Theme
            </button>
            <div class="absolute right-0 top-full pt-2 w-48 z-50 hidden group-hover:block">
                <div class="bg-white dark:bg-slate-800 rounded-md shadow-lg py-1 border border-slate-200 dark:border-slate-700">
                    <a href="#" onclick="setTheme('dark')" class="block px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 hover:text-indigo-600 dark:hover:text-white"><i class="fa-solid fa-moon w-5 text-indigo-500 dark:text-indigo-400"></i> Dark</a>
                    <a href="#" onclick="setTheme('light')" class="block px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 hover:text-indigo-600 dark:hover:text-white"><i class="fa-solid fa-sun w-5 text-amber-500 dark:text-amber-400"></i> Light</a>
                </div>
            </div>
        </div>

        <a href="/dashboard" class="text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-white transition-colors"><i class="fa-solid fa-chart-pie mr-1"></i> Dashboard</a>
        <a href="/planner" class="text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-white transition-colors"><i class="fa-solid fa-list-check mr-1"></i> Tasks</a>
        <a href="/focus" class="text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-white transition-colors"><i class="fa-solid fa-stopwatch mr-1"></i> Focus</a>
        <a href="/analytics" class="text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-white transition-colors"><i class="fa-solid fa-chart-line mr-1"></i> Analytics</a>
        <a href="/settings" class="text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-white transition-colors"><i class="fa-solid fa-gear mr-1"></i> Settings</a>
        
        <div class="relative group flex items-center h-full py-2">
            <button class="flex items-center space-x-2 focus:outline-none transition-colors">
                <div class="w-8 h-8 rounded-full bg-slate-800 dark:bg-slate-200 flex items-center justify-center text-white dark:text-slate-900 font-bold shadow-sm">
                    <%= user.name.charAt(0).toUpperCase() %>
                </div>
            </button>
            <div class="absolute right-0 top-full pt-2 w-48 z-50 hidden group-hover:block">
                <div class="bg-white dark:bg-slate-800 rounded-md shadow-lg py-1 border border-slate-200 dark:border-slate-700">
                    <div class="px-4 py-2 text-sm text-slate-500 dark:text-slate-400 border-b border-slate-200 dark:border-slate-700">Signed in as <br><span class="text-slate-800 dark:text-white truncate block"><%= user.email %></span></div>
                    <a href="/api/auth/logout" class="block px-4 py-2 text-sm text-red-500 dark:text-red-400 hover:bg-slate-50 dark:hover:bg-slate-700 hover:text-red-600 dark:hover:text-red-300 transition-colors"><i class="fa-solid fa-right-from-bracket mr-2"></i>Logout</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Mobile Navigation Toggle -->
    <div class="md:hidden flex items-center space-x-4">
        <div class="w-8 h-8 rounded-full bg-slate-800 dark:bg-slate-200 flex items-center justify-center text-white dark:text-slate-900 font-bold shadow-sm text-sm">
            <%= user.name.charAt(0).toUpperCase() %>
        </div>
        <button onclick="document.getElementById('mobile-menu').classList.toggle('hidden')" class="text-slate-600 dark:text-slate-300 focus:outline-none">
            <i class="fa-solid fa-bars text-2xl"></i>
        </button>
    </div>
</nav>

<!-- Mobile Menu -->
<div id="mobile-menu" class="hidden md:hidden glass mx-4 mt-2 p-4 flex flex-col space-y-4 z-40 relative">
    <a href="/dashboard" class="text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-white"><i class="fa-solid fa-chart-pie mr-2"></i> Dashboard</a>
    <a href="/planner" class="text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-white"><i class="fa-solid fa-list-check mr-2"></i> Tasks</a>
    <a href="/focus" class="text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-white"><i class="fa-solid fa-stopwatch mr-2"></i> Focus</a>
    <a href="/analytics" class="text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-white"><i class="fa-solid fa-chart-line mr-2"></i> Analytics</a>
    <a href="/settings" class="text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-white"><i class="fa-solid fa-gear mr-2"></i> Settings</a>
    <div class="border-t border-slate-200 dark:border-slate-700 pt-4 flex justify-between items-center">
        <div>
            <button onclick="setTheme('dark')" class="text-slate-600 dark:text-slate-300 hover:text-indigo-600 dark:hover:text-white mr-4"><i class="fa-solid fa-moon text-lg"></i></button>
            <button onclick="setTheme('light')" class="text-slate-600 dark:text-slate-300 hover:text-amber-500 dark:hover:text-amber-400"><i class="fa-solid fa-sun text-lg"></i></button>
        </div>
        <a href="/api/auth/logout" class="text-red-500 hover:text-red-600"><i class="fa-solid fa-right-from-bracket mr-2"></i>Logout</a>
    </div>
</div>
<% } %>
